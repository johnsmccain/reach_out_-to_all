# Cloudinary Configuration
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
VITE_CLOUDINARY_API_KEY=your_api_key
VITE_CLOUDINARY_API_NAME=your_cloud_name
VITE_CLOUDINARY_API_SECRET=your_api_secret

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# DePay Configuration
VITE_DEPAY=your_depay_public_key
VITE_DEPAY_INTEGRATION_ID=your_integration_id

# Paystack Configuration
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# EmailJS Configuration
VITE_PUBLIC_KEY=your_emailjs_public_key
VITE_SERVICE_ID=your_service_id

# Google Sheets API
VITE_SHEET_API_KEY=your_google_sheets_api_key

# Supabase Configuration
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co

# PDF Service Configuration
PDF_SERVICE_PORT=3001
VITE_PDF_SERVICE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
